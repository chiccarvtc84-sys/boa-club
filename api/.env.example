# === Serveur ===
PORT=8080
ENV=development
LOG_LEVEL=debug

# === Base de données ===
# Port 5433 pour ne pas entrer en conflit avec un autre Postgres local
DATABASE_URL=postgres://boa:boa_dev_password@localhost:5433/boa_club?sslmode=disable

# === Redis ===
# Port 6380 pour ne pas entrer en conflit avec un autre Redis local
REDIS_URL=redis://localhost:6380/0

# === JWT ===
# IMPORTANT: en production, génère une clé aléatoire avec: openssl rand -hex 64
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# === Bcrypt ===
BCRYPT_COST=12

# === Email (Resend) ===
# Mettre EMAIL_PROVIDER=mock en dev pour logger les mails au lieu de les envoyer.
# En prod, EMAIL_PROVIDER=resend + clé API Resend + domaine vérifié.
EMAIL_PROVIDER=mock
EMAIL_API_KEY=
EMAIL_FROM=Boa Club <noreply@clubedesportivoboa.fr>

# === Cloudflare R2 (stockage photos, à configurer plus tard) ===
R2_ENDPOINT=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=boa-club-uploads

# === Firebase Cloud Messaging (push notifications) ===
# Télécharger depuis Firebase Console → Project Settings → Service Accounts
# → "Generate new private key" → mettre le .json dans api/firebase-admin-key.json
FCM_CREDENTIALS_FILE=./firebase-admin-key.json
